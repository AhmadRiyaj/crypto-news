# .env.example — Copy to .env and fill in values

# Database (SQLite)
# DATABASE_URL="file:./dev.db"
DATABASE_URL="file:./prisma/dev.db"

# Admin panel password — make it strong!
ADMIN_PASSWORD="changeme123"

# Your site URL (update after deploy)
NEXT_PUBLIC_SITE_URL="https://your-site.onrender.com"
NEXT_PUBLIC_SITE_NAME="CryptoPulse"

# ✅ NO CRYPTO NEWS API KEY NEEDED!
# News is fetched free from:
# - cryptocurrency.cv (no key, 200+ sources)
# - CoinGecko (no key, 100+ publishers)
# - RSS feeds (Decrypt, CryptoSlate, CoinJournal, Bitcoin Magazine)
